<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Heredar de stock.view_stock_product_tree que añade qty_available y virtual_available.
        Esta vista SIEMPRE existe en Odoo con el módulo stock instalado.
        
        Usamos prioridad 100 para que se aplique DESPUÉS de cualquier otra vista que pueda
        existir (como product_stock_state con prioridad 16).
    -->
    <record id="view_product_product_tree_inherit_packaging" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.packaging</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.view_stock_product_tree"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <!-- Añadir después de virtual_available con posición 'after' -->
            <xpath expr="//field[@name='virtual_available']" position="after">
                <field name="packaging_quantity_available" 
                       string="Embalajes Disponibles" 
                       widget="float"
                       optional="show"
                       decoration-info="packaging_quantity_available &gt; 0"/>
            </xpath>
        </field>
    </record>
</odoo>
