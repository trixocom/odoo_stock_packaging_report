<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Heredar de la vista de product_stock_state que es la que finalmente se muestra
        en el reporte de Existencias en Odoo 18 EE.
        
        La vista product_stock_state.view_product_product_tree (ID 3098) añade el campo
        'stock_state' después de 'virtual_available', por lo que nosotros añadimos
        nuestro campo después de 'stock_state' para que aparezca correctamente.
    -->
    <record id="view_product_product_tree_inherit_packaging" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.packaging</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product_stock_state.view_product_product_tree"/>
        <field name="priority" eval="17"/>
        <field name="arch" type="xml">
            <!-- Añadir después del campo stock_state -->
            <field name="stock_state" position="after">
                <field name="packaging_quantity_available" 
                       string="Embalajes Disponibles" 
                       widget="float"
                       optional="show"
                       decoration-info="packaging_quantity_available &gt; 0"/>
            </field>
        </field>
    </record>
</odoo>
