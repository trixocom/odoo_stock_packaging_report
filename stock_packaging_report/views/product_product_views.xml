<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        VISTA 1: Heredar de la vista base de product.product
        Esto asegura que el campo esté disponible en todas las vistas list
    -->
    <record id="view_product_product_tree_inherit_packaging_base" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.packaging.base</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <!-- Añadir después del campo 'lst_price' que existe en la vista base -->
            <field name="lst_price" position="after">
                <field name="packaging_quantity_available" 
                       string="Embalajes Disponibles" 
                       widget="float"
                       optional="hide"/>
            </field>
        </field>
    </record>

    <!-- 
        VISTA 2: Heredar de la vista de stock que añade qty_available y virtual_available
        Esto coloca el campo justo después de las columnas de stock
    -->
    <record id="view_product_product_tree_inherit_packaging_stock" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.packaging.stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.view_stock_product_tree"/>
        <field name="priority" eval="99"/>
        <field name="arch" type="xml">
            <!-- Añadir después de virtual_available -->
            <field name="virtual_available" position="after">
                <field name="packaging_quantity_available" 
                       string="Embalajes Disponibles" 
                       widget="float"
                       optional="show"
                       decoration-info="packaging_quantity_available &gt; 0"/>
            </field>
        </field>
    </record>
</odoo>
