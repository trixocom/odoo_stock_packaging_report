<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modificar el smart button de stock en el formulario del producto -->
    <record id="product_template_form_view_inherit_packaging_button" model="ir.ui.view">
        <field name="name">product.template.form.inherit.packaging.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Reemplazar el botón de "On Hand" por uno que muestre embalajes -->
            <xpath expr="//button[@name='action_open_quants']" position="replace">
                <button name="action_open_quants" type="object" class="oe_stat_button" icon="fa-cubes" 
                        context="{'search_default_internal_loc': 1}">
                    <field name="packaging_quantity_available" widget="statinfo" string="Disponible"/>
                    <div class="o_stat_info">
                        <span class="o_stat_text"><field name="packaging_name_display" invisible="1"/><t t-esc="record.packaging_name_display.value or 'Unidades'"/></span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
