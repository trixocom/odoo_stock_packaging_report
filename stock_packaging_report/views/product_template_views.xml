<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modificar el smart button EXISTENTE de stock para mostrar embalajes -->
    <record id="product_template_form_view_modify_stock_button" model="ir.ui.view">
        <field name="name">product.template.form.modify.stock.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Reemplazar todo el contenido del div dentro del botón -->
            <xpath expr="//button[@name='action_open_quants']/div[@class='o_field_widget o_stat_info']" position="replace">
                <div class="o_field_widget o_stat_info">
                    <span class="o_stat_value">
                        <field name="packaging_quantity_available" widget="float"/>
                    </span>
                    <span class="o_stat_text">Disponible</span>
                    <span class="o_stat_text">
                        <field name="packaging_name_display"/>
                    </span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
