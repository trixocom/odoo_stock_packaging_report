<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar del formulario base del producto para modificar el smart button de stock -->
    <record id="product_template_form_view_inherit_packaging_button" model="ir.ui.view">
        <field name="name">product.template.form.inherit.packaging.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Agregar nuestro smart button al button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_quants" type="object" 
                        class="oe_stat_button" 
                        icon="fa-cubes"
                        context="{'search_default_internal_loc': 1}"
                        invisible="type == 'service'">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="packaging_quantity_available"/>
                        </span>
                        <span class="o_stat_text">Disponible</span>
                        <span class="o_stat_text">
                            <field name="packaging_name_display"/>
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
    
    <!-- Ocultar el smart button original de stock usando invisible -->
    <record id="product_template_form_view_hide_original_stock_button" model="ir.ui.view">
        <field name="name">product.template.form.hide.stock.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Ocultar el botón original -->
            <xpath expr="//button[@name='action_open_quants']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
