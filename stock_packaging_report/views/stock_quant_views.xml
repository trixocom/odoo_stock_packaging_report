<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar la vista tree del reporte de stock para añadir la columna de embalajes -->
    <record id="view_stock_quant_tree_inherit_packaging" model="ir.ui.view">
        <field name="name">stock.quant.tree.inherit.packaging</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
        <field name="arch" type="xml">
            <!-- Añadir la columna de cantidad de embalajes después de la columna de unidad -->
            <xpath expr="//list/field[@name='product_uom_id']" position="after">
                <field name="packaging_quantity" 
                       string="Cantidad de Embalajes" 
                       widget="float"
                       decoration-info="packaging_quantity &gt; 0"/>
            </xpath>
        </field>
    </record>

    <!-- También heredar la vista editable del inventario para incluir el campo -->
    <record id="view_stock_quant_tree_editable_inherit_packaging" model="ir.ui.view">
        <field name="name">stock.quant.tree.editable.inherit.packaging</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <!-- Añadir la columna después de product_uom_id -->
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="packaging_quantity" 
                       string="Cantidad de Embalajes" 
                       widget="float" 
                       readonly="1"
                       decoration-info="packaging_quantity &gt; 0"/>
            </xpath>
        </field>
    </record>
</odoo>
